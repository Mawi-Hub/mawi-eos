generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  role         String   // ceo, sales, cs, product, engineering
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  ownedMetrics      ScorecardMetric[]
  scorecardEntries  ScorecardEntry[]
  rocks             Rock[]
  winsAndChallenges WinChallenge[]
  issuesRaised      L10Issue[]      @relation("issuesRaised")
  issuesOwned       L10Issue[]      @relation("issuesOwned")
  commitments       L10Commitment[]
  accountabilityRole AccountabilityRole?
  planKpisOwned     PlanKPI[]
  planProposals     PlanProposal[]
  planActionsOwned  PlanAction[]
  preReadReads        L10PreReadRead[]
  annotationsAuthored L10Annotation[]  @relation("annotationsAuthored")
  annotationsResolved L10Annotation[]  @relation("annotationsResolved")
  issueVotes          L10IssueVote[]
  coveragesCreated    L10Coverage[]

  @@map("users")
}

model Quarter {
  id        String   @id @default(uuid())
  year      Int
  quarter   Int
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  isActive  Boolean  @default(false) @map("is_active")
  planId    String?  @map("plan_id")
  createdAt DateTime @default(now()) @map("created_at")

  plan             Plan?            @relation(fields: [planId], references: [id])
  scorecardEntries ScorecardEntry[]
  rocks            Rock[]
  winsAndChallenges WinChallenge[]
  l10Meetings      L10Meeting[]

  @@unique([year, quarter])
  @@map("quarters")
}

model ScorecardMetric {
  id              String   @id @default(uuid())
  name            String
  category        String   // revenue_health, sales_health, customer_success, product_engineering, financial_health
  ownerId         String   @map("owner_id")
  targetValue     String?  @map("target_value")
  targetNumeric   Float?   @map("target_numeric")
  targetDirection String   @default("above") @map("target_direction") // above, below, equal
  frequency       String   // weekly, biweekly, monthly
  unit            String?  // %, $, hours, count, ratio, months
  calculation     String?
  dataSource      String   @default("manual") @map("data_source") // manual, chartmogul, hubspot, posthog
  sortOrder       Int      @default(0) @map("sort_order")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  owner        User             @relation(fields: [ownerId], references: [id])
  entries      ScorecardEntry[]
  linkedIssues L10Issue[]       @relation("issuesLinkedMetric")

  @@map("scorecard_metrics")
}

model ScorecardEntry {
  id            String   @id @default(uuid())
  metricId      String   @map("metric_id")
  quarterId     String   @map("quarter_id")
  periodStart   DateTime @map("period_start")
  periodEnd     DateTime @map("period_end")
  actualValue   Float?   @map("actual_value")
  actualDisplay String?  @map("actual_display")
  status        String   @default("pending") // on_track, off_track, riesgo, pending
  notes         String?
  enteredById   String?  @map("entered_by_id")
  autoSynced    Boolean  @default(false) @map("auto_synced")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  metric    ScorecardMetric @relation(fields: [metricId], references: [id])
  quarter   Quarter         @relation(fields: [quarterId], references: [id])
  enteredBy User?           @relation(fields: [enteredById], references: [id])

  @@unique([metricId, periodStart])
  @@map("scorecard_entries")
}

model Rock {
  id           String   @id @default(uuid())
  quarterId    String   @map("quarter_id")
  ownerId      String   @map("owner_id")
  title        String
  description  String
  deliverable  String
  doneCriteria String   @map("done_criteria")
  progress     Int      @default(0)
  risk         String?
  status       String   @default("on_track") // on_track, off_track, riesgo, done, not_done
  finalStatus  String?  @map("final_status") // done, not_done (set at quarter end)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  quarter      Quarter    @relation(fields: [quarterId], references: [id])
  owner        User       @relation(fields: [ownerId], references: [id])
  linkedIssues L10Issue[] @relation("issuesLinkedRock")

  @@map("rocks")
}

model WinChallenge {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  quarterId      String   @map("quarter_id")
  reportDate     DateTime @map("report_date")
  entryType      String   @default("win") @map("entry_type") // win, challenge
  wins           String?  // What was done (for wins)
  result         String?  // Measurable result (for wins)
  keyChallenge   String?  @map("key_challenge") // Challenge description
  priority       String   @default("medio") // alto, medio, bajo (for challenges)
  followUpAction String?  @map("follow_up_action") // Next action (for challenges)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id])
  quarter Quarter @relation(fields: [quarterId], references: [id])

  @@map("wins_challenges")
}

model L10Meeting {
  id              String    @id @default(uuid())
  quarterId       String    @map("quarter_id")
  date            DateTime
  status          String    @default("upcoming") // upcoming, in_progress, completed
  phase           String    @default("preread") // preread, voting, ids, commitments, closed
  prereadDeadline DateTime? @map("preread_deadline")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  quarter      Quarter          @relation(fields: [quarterId], references: [id])
  issues       L10Issue[]
  commitments  L10Commitment[]
  preReadReads L10PreReadRead[]
  annotations  L10Annotation[]
  coverages    L10Coverage[]

  @@map("l10_meetings")
}

model L10Issue {
  id             String    @id @default(uuid())
  meetingId      String    @map("meeting_id")
  raisedById     String    @map("raised_by_id")
  title          String
  description    String?
  priority       String    @default("medio") // alto, medio, bajo
  idsStatus      String    @default("identify") @map("ids_status") // identify, discuss, solve, resolved
  resolution     String?
  ownerId        String?   @map("owner_id")
  dueDate        DateTime? @map("due_date")
  linkedRockId   String?   @map("linked_rock_id")
  linkedMetricId String?   @map("linked_metric_id")
  submittedAt    DateTime? @map("submitted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  meeting      L10Meeting       @relation(fields: [meetingId], references: [id])
  raisedBy     User             @relation("issuesRaised", fields: [raisedById], references: [id])
  owner        User?            @relation("issuesOwned", fields: [ownerId], references: [id])
  linkedRock   Rock?            @relation("issuesLinkedRock", fields: [linkedRockId], references: [id])
  linkedMetric ScorecardMetric? @relation("issuesLinkedMetric", fields: [linkedMetricId], references: [id])
  votes        L10IssueVote[]
  coverages    L10Coverage[]

  @@map("l10_issues")
}

model L10Commitment {
  id        String    @id @default(uuid())
  meetingId String    @map("meeting_id")
  ownerId   String    @map("owner_id")
  action    String
  dueDate   DateTime  @map("due_date")
  done      Boolean   @default(false)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  meeting L10Meeting @relation(fields: [meetingId], references: [id])
  owner   User       @relation(fields: [ownerId], references: [id])

  @@map("l10_commitments")
}

model L10PreReadRead {
  id        String   @id @default(uuid())
  meetingId String   @map("meeting_id")
  userId    String   @map("user_id")
  readAt    DateTime @default(now()) @map("read_at")

  meeting L10Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User       @relation(fields: [userId], references: [id])

  @@unique([meetingId, userId])
  @@map("l10_preread_reads")
}

model L10Annotation {
  id           String    @id @default(uuid())
  meetingId    String    @map("meeting_id")
  authorId     String    @map("author_id")
  targetType   String    @map("target_type") // rock, metric, win, challenge
  targetId     String    @map("target_id")
  tag          String    // clarificar, discutir
  comment      String
  resolvedAt   DateTime? @map("resolved_at")
  resolvedById String?   @map("resolved_by_id")
  createdAt    DateTime  @default(now()) @map("created_at")

  meeting    L10Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  author     User       @relation("annotationsAuthored", fields: [authorId], references: [id])
  resolvedBy User?      @relation("annotationsResolved", fields: [resolvedById], references: [id])

  @@index([meetingId, targetType, targetId])
  @@map("l10_annotations")
}

model L10IssueVote {
  id        String   @id @default(uuid())
  issueId   String   @map("issue_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  issue L10Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user  User     @relation(fields: [userId], references: [id])

  @@unique([issueId, userId])
  @@map("l10_issue_votes")
}

model L10Coverage {
  id           String   @id @default(uuid())
  meetingId    String   @map("meeting_id")
  sourceType   String   @map("source_type") // metric, rock
  sourceId     String   @map("source_id")
  coverageType String   @map("coverage_type") // linked_issue, no_action_note
  issueId      String?  @map("issue_id")
  note         String?
  createdById  String   @map("created_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  meeting   L10Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  issue     L10Issue?  @relation(fields: [issueId], references: [id])
  createdBy User       @relation(fields: [createdById], references: [id])

  @@unique([meetingId, sourceType, sourceId])
  @@map("l10_coverages")
}

model AccountabilityRole {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  title              String
  responsibilities   String[]
  decidesAlone       String[] @map("decides_alone")
  requiresApproval   String[] @map("requires_approval")
  keyMetrics         String[] @map("key_metrics")
  sortOrder          Int      @default(0) @map("sort_order")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("accountability_roles")
}

model ApiSyncCache {
  id       String   @id @default(uuid())
  source   String   // chartmogul, hubspot, posthog
  dataKey  String   @map("data_key")
  data     Json
  syncedAt DateTime @map("synced_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([source, dataKey])
  @@map("api_sync_cache")
}

enum PlanType {
  ANNUAL
  SEMESTRAL

  @@map("plan_type")
}

enum PlanStatus {
  DRAFT
  ACTIVE
  CLOSED

  @@map("plan_status")
}

enum KPICategory {
  REVENUE
  RETENTION
  GROWTH
  EFFICIENCY

  @@map("kpi_category")
}

enum KPIDirection {
  ABOVE
  BELOW

  @@map("kpi_direction")
}

enum KPISourceType {
  MANUAL
  CHARTMOGUL
  HUBSPOT
  POSTHOG
  SCORECARD

  @@map("kpi_source_type")
}

enum ProposalStatus {
  RECEIVED
  REVIEWING
  APPROVED
  REJECTED

  @@map("proposal_status")
}

enum MilestoneStatus {
  PENDING
  MET
  MISSED

  @@map("milestone_status")
}

enum PlanArea {
  NORTH_STAR
  COMERCIAL
  CUSTOMER_SUCCESS
  PRODUCTO
  INGENIERIA

  @@map("plan_area")
}

enum ActionStatus {
  PLANNED
  IN_PROGRESS
  DONE
  BLOCKED

  @@map("action_status")
}

enum RiskStatus {
  ACTIVE
  MITIGATING
  RESOLVED

  @@map("risk_status")
}

model Plan {
  id        String     @id @default(uuid())
  name      String     @unique
  type      PlanType
  startDate DateTime   @map("start_date")
  endDate   DateTime   @map("end_date")
  status    PlanStatus @default(DRAFT)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  quarters  Quarter[]
  kpis      PlanKPI[]
  proposals PlanProposal[]
  actions   PlanAction[]
  risks     PlanRisk[]

  @@map("plans")
}

model PlanKPI {
  id           String        @id @default(uuid())
  planId       String        @map("plan_id")
  name         String
  slug         String
  category     KPICategory
  area         PlanArea      @default(NORTH_STAR)
  baseline     Float
  target       Float
  unit         String
  direction    KPIDirection
  ownerId      String        @map("owner_id")
  sourceType   KPISourceType @default(MANUAL) @map("source_type")
  sourceKey    String?       @map("source_key")
  displayOrder Int           @default(0) @map("display_order")
  isPrincipal  Boolean       @default(false) @map("is_principal")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  plan    Plan           @relation(fields: [planId], references: [id], onDelete: Cascade)
  owner   User           @relation(fields: [ownerId], references: [id])
  entries PlanKPIEntry[]

  @@unique([planId, slug])
  @@map("plan_kpis")
}

model PlanKPIEntry {
  id        String   @id @default(uuid())
  kpiId     String   @map("kpi_id")
  period    DateTime
  projected Float
  actual    Float?
  note      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  kpi PlanKPI @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@unique([kpiId, period])
  @@map("plan_kpi_entries")
}

model PlanProposal {
  id          String         @id @default(uuid())
  planId      String         @map("plan_id")
  ownerId     String         @map("owner_id")
  area        String
  status      ProposalStatus @default(RECEIVED)
  submittedAt DateTime?      @map("submitted_at")
  content     String
  resources   Json
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  plan       Plan                @relation(fields: [planId], references: [id], onDelete: Cascade)
  owner      User                @relation(fields: [ownerId], references: [id])
  milestones ProposalMilestone[]

  @@map("plan_proposals")
}

model ProposalMilestone {
  id          String          @id @default(uuid())
  proposalId  String          @map("proposal_id")
  quarter     String
  description String
  targetDate  DateTime        @map("target_date")
  status      MilestoneStatus @default(PENDING)
  createdAt   DateTime        @default(now()) @map("created_at")

  proposal PlanProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@map("proposal_milestones")
}

model PlanAction {
  id             String       @id @default(uuid())
  planId         String       @map("plan_id")
  area           PlanArea
  ownerId        String?      @map("owner_id")
  title          String
  description    String?
  expectedImpact String?      @map("expected_impact")
  status         ActionStatus @default(PLANNED)
  displayOrder   Int          @default(0) @map("display_order")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  plan  Plan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  owner User? @relation(fields: [ownerId], references: [id])

  @@map("plan_actions")
}

model PlanRisk {
  id           String     @id @default(uuid())
  planId       String     @map("plan_id")
  area         PlanArea
  title        String
  description  String?
  status       RiskStatus @default(ACTIVE)
  displayOrder Int        @default(0) @map("display_order")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("plan_risks")
}
